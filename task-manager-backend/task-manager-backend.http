@task_manager_backend_HostAddress = http://localhost:5083

### Get task options (categories, priorities, statuses)
GET {{task_manager_backend_HostAddress}}/api/tasks/options
Accept: application/json

### Get all tasks
GET {{task_manager_backend_HostAddress}}/api/tasks
Accept: application/json

### Get task by id
GET {{task_manager_backend_HostAddress}}/api/tasks/1
Accept: application/json

### Create a new task
POST {{task_manager_backend_HostAddress}}/api/tasks
Content-Type: application/json

{
  "title": "Complete Angular Assignment",
  "description": "Finish the task manager application with all requirements including http integration",
  "category": "education",
  "priority": "high",
  "dueDate": "2030-12-15T00:00:00.000Z",
  "status": "in-progress"
}

### Update a task
PUT {{task_manager_backend_HostAddress}}/api/tasks/1
Content-Type: application/json

{
  "title": "Complete Angular Assignment - Updated",
  "description": "Updated description",
  "status": "completed",
  "priority": "high"
}

### Delete a task
DELETE {{task_manager_backend_HostAddress}}/api/tasks/1

### Get tasks by status
GET {{task_manager_backend_HostAddress}}/api/tasks/status/in-progress
Accept: application/json

### Get tasks by priority
GET {{task_manager_backend_HostAddress}}/api/tasks/priority/high
Accept: application/json

### Get tasks by category
GET {{task_manager_backend_HostAddress}}/api/tasks/category/education
Accept: application/json

###

### ====== EMPLOYEE ENDPOINTS ======

### Get employee options (departments, statuses, locations)
GET {{task_manager_backend_HostAddress}}/api/employees/options
Accept: application/json

### Get all employees
GET {{task_manager_backend_HostAddress}}/api/employees
Accept: application/json

### Get employee by id
GET {{task_manager_backend_HostAddress}}/api/employees/1
Accept: application/json

### Create a new employee
POST {{task_manager_backend_HostAddress}}/api/employees
Content-Type: application/json

{
  "firstName": "Rajesh",
  "lastName": "Kumar",
  "email": "rajesh.kumar@company.com",
  "phone": "+91 98765 43210",
  "department": "Engineering",
  "designation": "Senior Software Engineer",
  "salary": 95000,
  "joinDate": "2019-03-15T00:00:00.000Z",
  "status": "active",
  "location": "Bangalore",
  "managerId": 5,
  "avatar": "https://i.pravatar.cc/150?u=1"
}

### Create multiple employees in batch
POST {{task_manager_backend_HostAddress}}/api/employees/batch
Content-Type: application/json

[
  {
    "firstName": "Rajesh",
